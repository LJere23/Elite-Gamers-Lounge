generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id                  String    @id @default(uuid())
  name                String
  gamerTag            String    @unique
  email               String    @unique
  phone               String?
  dateOfBirth         DateTime?
  city                String    @default("Gweru")
  age                 Int?
  membershipTier      String    @default("Villager")
  membershipExpiresAt DateTime?
  status              String    @default("active")
  xp                  Int       @default(0)
  rank                String    @default("Villager")
  visitCount          Int       @default(0)
  favoriteGame        String?
  joinedAt            DateTime  @default(now())
  lastVisitAt         DateTime?
  pin                 String?
  pinSalt             String?
  avatarUrl           String?

  // Founder system
  isFounder          Boolean   @default(false)
  founderNumber      Int?
  founderPriceLocked Boolean   @default(false)
  founderRenewalDue  DateTime?

  // Gaming period tracking (resets weekly for Warrior, monthly for others)
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  hoursUsedThisPeriod Float     @default(0)

  // Daily cap tracking (Warrior: 1hr/day, Legend: 1hr/day)
  hoursUsedToday  Float   @default(0)
  lastSessionDate String? // "YYYY-MM-DD" UTC — resets daily

  // Monthly perks period (racing races, tournament entries, Wi-Fi)
  // Separate from gaming period so Warriors get monthly perks tracked monthly
  perksMonthStart   DateTime?
  perksMonthEnd     DateTime?
  racingRacesUsed   Int   @default(0) // Hero: 1 free, Legend: 3 free
  fridayEntriesUsed Int   @default(0) // Warrior/Hero: 1 free, Legend: unlimited
  racingLeagueUsed  Int   @default(0) // Legend: 1 free
  wifiMinutesUsed   Float @default(0) // Warrior: 30 min/week (tracked on gaming period)

  // Legend exclusive
  showOnLeaderboardWall Boolean @default(false)

  // Renewal notifications
  membershipRenewalNotifiedAt DateTime?

  referredById   String?
  referredBy     Player?  @relation("PlayerReferrals", fields: [referredById], references: [id])
  referrals      Player[] @relation("PlayerReferrals")

  cxpBalance    Int @default(0)

  titles             PlayerTitle[]
  xpLedger           XpLedger[]
  cxpLedger          CxpLedger[]
  jobCompletions     JobCompletion[]
  entries            TournamentEntry[]
  notifications      Notification[]
  challengeProgress  PlayerChallengeProgress[]
  bettingAccess      BettingPoolAccess[]
  bettingStakes      BettingStake[]

  @@index([membershipTier])
  @@index([rank])
  @@index([xp])
  @@index([membershipExpiresAt])
}

model PlayerTitle {
  id        String   @id @default(uuid())
  playerId  String
  title     String
  awardedAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model XpLedger {
  id        String   @id @default(uuid())
  playerId  String
  amount    Int
  source    String
  jobId     String?
  note      String?
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([createdAt])
}

model Job {
  id          String  @id @default(uuid())
  name        String
  description String
  xpReward    Int
  active      Boolean @default(true)
  jobType     String  @default("standard")

  completions JobCompletion[]
}

model JobCompletion {
  id          String   @id @default(uuid())
  playerId    String
  jobId       String
  contextId   String?
  completedAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([playerId, jobId, contextId])
}

model Device {
  id               String  @id @default(uuid())
  name             String
  type             String
  hourlyRate       Float
  supportedGames   String  @default("[]")
  status           String  @default("available")
  location         String  @default("Main Floor")
  currentSessionId String?
}

model Session {
  id               String   @id @default(uuid())
  playerName       String
  playerGamerTag   String?
  game             String
  deviceId         String
  deviceName       String
  startTime        DateTime
  endTime          DateTime
  durationHours    Float
  totalPrice       Float
  remainingMinutes Int      @default(0)
  status           String   @default("ACTIVE")
  createdAt        DateTime @default(now())

  // Membership coverage
  membershipCovered Boolean @default(false)
  membershipDiscount Float  @default(0)

  @@index([status])
  @@index([deviceId])
  @@index([playerGamerTag])
  @@index([createdAt])
}

model WifiSession {
  id               String   @id @default(uuid())
  name             String
  device           String   @default("Laptop")
  station          String   @default("Main Floor")
  status           String   @default("active")
  startedAt        DateTime @default(now())
  expiresAt        DateTime
  durationHours    Float
  remainingMinutes Int      @default(0)
  priceUsd         Float    @default(0)
}

model Tournament {
  id               String    @id @default(uuid())
  name             String
  game             String
  category         String
  format           String
  status           String    @default("scheduled")
  startAt          DateTime
  endAt            DateTime
  entries          Int       @default(0)
  entryFee         Float     @default(0)
  prizeUsd         Float     @default(0)
  prizeDescription String    @default("")
  scoringSystem    String    @default("best_of_1")
  circuit          String?   // Racing Sim League: the circuit being timed
  xpReward         Int       @default(3) // XP awarded to player on entry
  currentRound     Int?
  winnerId         String?
  winnerName       String?
  runnerUpId       String?
  runnerUpName     String?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  tournamentEntries TournamentEntry[]
  matches           TournamentMatch[]
  bettingPools      BettingPool[]
}

model TournamentEntry {
  id           String   @id @default(uuid())
  tournamentId String
  playerId     String?
  playerName   String
  guestName    String?
  registeredAt DateTime @default(now())
  status       String   @default("registered")
  points       Int      @default(0)
  wins         Int      @default(0)
  losses       Int      @default(0)
  bestLapTime  Float?
  lapTimeNote  String?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player?    @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([tournamentId])
  @@index([playerId])
}

model TournamentMatch {
  id           String   @id @default(uuid())
  tournamentId String
  playerAId    String
  playerAName  String
  playerBId    String
  playerBName  String
  scheduledAt  DateTime @default(now())
  status       String   @default("scheduled")
  scoreA       Int?
  scoreB       Int?
  winnerId     String?
  winnerName   String?
  round        Int      @default(1)
  stage        String   @default("Round 1")
  isBye        Boolean  @default(false)
  bracket      String   @default("winner")
  game1ScoreA  Int?
  game1ScoreB  Int?
  game2ScoreA  Int?
  game2ScoreB  Int?
  game3ScoreA  Int?
  game3ScoreB  Int?
  seriesWinsA  Int      @default(0)
  seriesWinsB  Int      @default(0)
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model MembershipPlan {
  id          String @id @default(uuid())
  name        String
  priceUsd    Float
  period      String
  description String
  perks       String @default("[]")
}

model Announcement {
  id             String    @id @default(uuid())
  message        String
  tournamentId   String?
  tournamentName String?
  winnerName     String?
  prizeAmount    String?
  type           String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?

  @@index([createdAt])
  @@index([expiresAt])
}

model Notification {
  id        String   @id @default(uuid())
  playerId  String?
  type      String   @default("info") // "rank_up" | "title" | "quest" | "xp"
  heading   String   @default("Notification")
  message   String
  read      Boolean  @default(false)
  severity  String   @default("info")
  createdAt DateTime @default(now())

  player Player? @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([read])
}

model StaffAccount {
  id        String   @id @default(uuid())
  name      String
  pin       String
  pinSalt   String
  role      String   @default("staff")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Challenge {
  id          String   @id @default(uuid())
  name        String
  description String
  icon        String   @default("⚔")
  type        String
  target      Int
  xpReward    Int      @default(10)
  weeklyReset Boolean  @default(true)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  progress PlayerChallengeProgress[]
}

model PlayerChallengeProgress {
  id          String    @id @default(uuid())
  playerId    String
  challengeId String
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  weekKey     String
  xpAwarded   Boolean   @default(false)

  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([playerId, challengeId, weekKey])
  @@index([playerId])
  @@index([weekKey])
}

model LoungeSettings {
  id                  String  @id @default("singleton")
  name                String  @default("Gweru's Gamers Lounge")
  tagline             String  @default("Gweru's Premier Gaming Experience")
  contactEmail        String  @default("")
  contactPhone        String  @default("")
  address             String  @default("Gweru, Zimbabwe")
  sessionRate         Float   @default(1.0)
  wifiRate            Float   @default(0.5)
  currency            String  @default("USD")
  openingTime         String  @default("09:00")
  closingTime         String  @default("22:00")
  whatsappNumber      String  @default("263784497531")
  adminPassword       String  @default("admin123")
  communityHeadline   String  @default("Join Our Gaming Community")
  communityBody       String  @default("Gweru's Gamers Lounge is more than a gaming venue — it's a community of competitive players, casual gamers, and esports enthusiasts all under one roof.")
  communityStat1Label String  @default("Members")
  communityStat1Value String  @default("200+")
  communityStat2Label String  @default("Tournaments")
  communityStat2Value String  @default("50+")
  communityStat3Label String  @default("Games Available")
  communityStat3Value String  @default("30+")
  countdownEnabled    Boolean @default(false)
  countdownTitle      String  @default("Next Event")
  countdownDate       String  @default("")

  // Founder system
  foundingSlotsCap       Int @default(50)
  foundingSlotsRemaining Int @default(50)

  // Double XP events
  doubleXpActive     Boolean   @default(false)
  doubleXpMultiplier Float     @default(2.0)
  doubleXpUntil      DateTime?
  doubleXpLabel      String    @default("Double XP Event")

  // Oracle Pool
  oraclePoolEnabled  Boolean   @default(false)
}

model TournamentTemplate {
  id           String   @id @default(uuid())
  templateName String
  defaultGame  String   @default("")
  category     String   @default("other")
  format       String   @default("knockout")
  scoringSystem String  @default("best_of_1")
  maxPlayers   Int      @default(8)
  walkInFee    Float    @default(0)
  circuit      String?  // e.g. "Spa-Francorchamps" — relevant for Racing Sim League

  // Tier pricing — stored as "free entries per month + discount after free"
  // -1 = unlimited free entries (e.g. Legend in Friday Mini, Hero/Legend in Chess)
  warriorFreeEntriesPerMonth Int   @default(0)
  warriorDiscountPercent     Float @default(0)
  heroFreeEntriesPerMonth    Int   @default(0)
  heroDiscountPercent        Float @default(0)
  legendFreeEntriesPerMonth  Int   @default(0)
  legendDiscountPercent      Float @default(0)

  xpReward         Int     @default(0)
  prizeDescription String  @default("")
  isEnabled        Boolean @default(true)
  createdAt        DateTime @default(now())
}

model Testimonial {
  id        String @id @default(uuid())
  name      String
  role      String
  message   String
  sortOrder Int    @default(0)
}

model Game {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model GalleryImage {
  id         String   @id @default(uuid())
  filename   String
  caption    String?
  sortOrder  Int      @default(0)
  uploadedAt DateTime @default(now())
}

model BlogPost {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  author      String    @default("Admin")
  imageUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CxpLedger {
  id          String   @id @default(uuid())
  playerId    String
  amount      Int      // positive = credit, negative = debit
  sourceType  String   // "mission" | "bet_stake" | "bet_payout" | "bet_refund" | "house_cut" | "admin_adjustment"
  sourceLabel String
  contextId   String?
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([createdAt])
}

model BettingPool {
  id                     String    @id @default(uuid())
  tournamentId           String
  scopeType              String    // "full_tournament" | "single_match"
  matchId                String?
  title                  String
  status                 String    @default("draft") // "draft"|"open"|"closed"|"settled"|"cancelled"
  houseCutPercent        Float     @default(20)
  totalPoolCxp           Int       @default(0)
  totalHouseCutCollected Int       @default(0)
  enabled                Boolean   @default(false)
  closesAt               DateTime
  settledAt              DateTime?
  createdAt              DateTime  @default(now())

  tournament Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  outcomes   BettingPoolOutcome[]
  access     BettingPoolAccess[]
  stakes     BettingStake[]

  @@index([tournamentId])
  @@index([status])
  @@index([matchId])
}

model BettingPoolAccess {
  id            String   @id @default(uuid())
  bettingPoolId String
  playerId      String
  invitedAt     DateTime @default(now())

  bettingPool BettingPool @relation(fields: [bettingPoolId], references: [id], onDelete: Cascade)
  player      Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([bettingPoolId, playerId])
  @@index([bettingPoolId])
  @@index([playerId])
}

model BettingPoolOutcome {
  id               String  @id @default(uuid())
  bettingPoolId    String
  label            String
  outcomeType      String  // "player" | "draw"
  linkedEntryId    String?
  linkedPlayerSlot String? // "playerA" | "playerB"
  totalStakedCxp   Int     @default(0)

  bettingPool BettingPool  @relation(fields: [bettingPoolId], references: [id], onDelete: Cascade)
  stakes      BettingStake[]

  @@index([bettingPoolId])
}

model BettingStake {
  id            String   @id @default(uuid())
  bettingPoolId String
  outcomeId     String
  playerId      String
  amountCxp     Int
  placedAt      DateTime @default(now())
  settled       Boolean  @default(false)
  payoutCxp     Int?

  bettingPool BettingPool        @relation(fields: [bettingPoolId], references: [id], onDelete: Cascade)
  outcome     BettingPoolOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  player      Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([bettingPoolId, playerId])
  @@index([bettingPoolId])
  @@index([outcomeId])
  @@index([playerId])
}
